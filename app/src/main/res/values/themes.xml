<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.StrobeLight" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/surface</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <!-- Preset buttons: outlined, small, equal-weight -->
    <style name="PresetButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginHorizontal">3dp</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="strokeColor">@color/accent_cyan</item>
        <item name="android:textSize">11sp</item>
        <item name="android:paddingHorizontal">2dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
